#!/usr/bin/env bash
# uat-pre-commit-hook
# Pre-commit hook: runs uat against a local dev server.
#
# Configuration (env vars or .env file):
#   LINK_CHECK_PORT     - local dev server port (default: 3000)
#   LINK_CHECK_DISABLED - set to "1" or "true" to skip this hook
#   LINK_CHECK_MAX_PAGES - max pages to crawl (default: 50 for speed)
#   LINK_CHECK_BROWSER  - set to "1" or "true" to enable Playwright browser checks (default: off, slow)
#
# To disable permanently:
#   git config hooks.linkcheck false
#   — or —
#   LINK_CHECK_DISABLED=1 git commit ...
#   — or —
#   Remove with: ./setup-hooks.sh uninstall

set -euo pipefail

# Check for permanent disable via git config
if [ "$(git config --bool hooks.linkcheck 2>/dev/null)" = "false" ]; then
  exit 0
fi

# Check for env-based disable
if [ "${LINK_CHECK_DISABLED:-}" = "1" ] || [ "${LINK_CHECK_DISABLED:-}" = "true" ]; then
  exit 0
fi

# Resolve the worktree root even when this script is installed under .git/hooks.
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || {
  echo "[uat] Unable to determine the git worktree root."
  exit 1
}

# Load .env from the repository root if present.
if [ -f "${REPO_ROOT}/.env" ]; then
  set -a && source "${REPO_ROOT}/.env" && set +a
fi

PORT="${LINK_CHECK_PORT:-3000}"
MAX_PAGES="${LINK_CHECK_MAX_PAGES:-50}"
BROWSER_FLAG=""
if [ "${LINK_CHECK_BROWSER:-}" = "1" ] || [ "${LINK_CHECK_BROWSER:-}" = "true" ]; then
  BROWSER_FLAG="--browser"
fi
MAIN_SCRIPT="${REPO_ROOT}/main.ts"
TSX_BIN="${REPO_ROOT}/node_modules/.bin/tsx"

if [ ! -x "${TSX_BIN}" ]; then
  echo "[uat] Missing runtime dependency: ${TSX_BIN}"
  echo "[uat] Run npm install from ${REPO_ROOT} and retry."
  exit 1
fi

# Check if dev server is running
if ! curl -s --head --connect-timeout 2 "http://localhost:${PORT}" > /dev/null 2>&1; then
  echo "[uat] Dev server not running on port ${PORT} — skipping check."
  echo "[uat] Start your dev server and retry, or set LINK_CHECK_DISABLED=1 to skip."
  exit 0
fi

echo "[uat] Checking local site on port ${PORT} (max ${MAX_PAGES} pages${BROWSER_FLAG:+, browser checks enabled})..."
if ! "${TSX_BIN}" "${MAIN_SCRIPT}" check \
  --base-url "http://localhost:${PORT}" \
  --max-pages "${MAX_PAGES}" \
  --no-external \
  --concurrency 10 \
  --exit-on-failure \
  ${BROWSER_FLAG}; then
  echo ""
  echo "[uat] Broken links found. Fix them before committing."
  echo "[uat] To skip this check: LINK_CHECK_DISABLED=1 git commit ..."
  exit 1
fi

echo "[uat] All checks OK."
